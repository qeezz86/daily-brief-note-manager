    "WORDPRESS_APPLICATION_PASSWORD",
    "WORDPRESS_ALLOWED_USER_ID",
    "APP_ALLOWED_ORIGINS"
  ],
  "forbiddenProductionSecrets": [
    "WORDPRESS_LOCAL_MODE"
  ],
  "requiredReadOnlyChecks": [
    "rest-discovery",
    "wp-v2-namespace",
    "application-password-advertisement",
    "authenticated-users-me",
    "required-capabilities",
    "post-type",
    "statuses",
    "categories-full-catalog",
    "tags-full-catalog",
    "posts-read",
    "duplicate-slug",
    "taxonomy-mapping-revalidation",
    "publication-preview",
    "zero-blockers",
    "warning-review",
    "fingerprint-recorded"
  ],
  "requiredDraftChecks": [
    "migration-complete",
    "functions-deployed",
    "function-version-confirmed",
    "secrets-confirmed",
    "local-mode-absent",
    "diagnostics-ready",
    "owner-matches",
    "taxonomy-ready",
    "duplicate-slug-zero",
    "publication-plan-ready",
    "source-updated-at-matches",
    "fingerprint-matches",
    "no-succeeded-or-uncertain-attempt",
