  "expectedDraftStatus": "draft",
  "placeholders": [
    "<PROJECT_REF>",
    "<WORDPRESS_SITE_URL>",
    "<WORDPRESS_ALLOWED_USER_ID>",
    "<PRODUCTION_APP_ORIGIN>",
    "<PRODUCTION_DEPLOYMENT_COMMIT>"
